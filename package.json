{
  "name": "klook-cli",
  "version": "0.1.0",
  "description": "Klook.com CLI — search activities, trending, and pricing via Browser Bridge",
  "type": "module",
  "main": "dist/clis/klook/search.js",
  "bin": {
    "klook": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/clis/klook/search.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "@jackwener/opencli": ">=1.0.0"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@jackwener/opencli": "^1.6.1",
    "@types/node": "^22.13.10",
    "@types/sql.js": "^1.4.11",
    "tsx": "^4.19.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0"
  },
  "license": "MIT"
}
